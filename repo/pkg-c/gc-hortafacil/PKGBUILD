# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gc-hortafacil'
pkgdesc='Goylin: HortaFacil'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=26.0
pkgrel=0
arch=('x86_64')

source=(
	'hortafacil.tar'
	'hortafacil.desktop'
	'hortafacilicon.png'
)

noextract=('hortafacil.tar')

md5sums=('SKIP' 'SKIP' 'SKIP')

install='pkg.install'

depends=(
	'wine'	# A compatibility layer for running Windows programs
)

package() {
	install -Dm 644 -t ${pkgdir}/opt/hortafacil hortafacil.tar
	tar vxf ${pkgdir}/opt/hortafacil/hortafacil.tar --overwrite --directory=${pkgdir}/opt/hortafacil
	chmod -v 755 ${pkgdir}/opt/hortafacil/start.sh
	rm ${pkgdir}/opt/hortafacil/hortafacil.tar

	install -Dm 644 -t ${pkgdir}/usr/share/applications hortafacil.desktop
	install -Dm 644 -t ${pkgdir}/usr/share/icons hortafacilicon.png
}