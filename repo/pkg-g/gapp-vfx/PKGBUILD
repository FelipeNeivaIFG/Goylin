# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-vfx'
pkgdesc='Goylin: VFX Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.5
pkgrel=1
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'blender-3.6-bin'
	'blender-plugin-fspy'
	'godot-blender-exporter-git'
	# 'gconf'
	# 'xdialog'
	'openfx-arena'
	'openfx-gmic'
	# 'openfx-io' # FIX - Broken by ffmpeg update
	'openfx-misc'
	'gyroflow-ofx-bin' 
	'natron-bin'
	# 'natron-plugins-git' # Deppendency Hell
	'gyroflow-bin' # Untested remove of pulseaudio deppendency in favor of pipewire-pulse
	# 'fspy'
	'magicavoxel'
)

install='pkg.install'

package() {
	install -vDm 644 -t ${pkgdir}/etc/skel skel.tar
	tar vxf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm -v ${pkgdir}/etc/skel/skel.tar
}