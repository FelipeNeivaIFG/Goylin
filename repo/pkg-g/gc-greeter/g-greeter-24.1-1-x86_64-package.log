linguas="af am an ar ast az bem be bg bn bo br bs ca ca@valencia ce ckb crh cs cv cy da de el en_AU en_CA en_GB eo es et eu fa fil fi fo fr_CA fr frp fy ga gd gl gu he hi hr ht hu hy ia id ie is it ja ka kab kk kl km kn ko ku kw ky la lb lo lt lv mg mhr mi ml mr ms my nap nb ne nl nn oc os pa pl ps pt_BR pt ro ru sa sc sd se shn si sk sl sq sr sr@latin sv sw szl ta te tg th ti tr ug uk ur uz vec vi wae zgh zh_CN zh_HK zh_TW "; \
for lang in $linguas; do \
  dir=/build/g-greeter/pkg/g-greeter/usr/share/locale/$lang/LC_MESSAGES; \
  /bin/sh /build/g-greeter/src/slick-greeter-2.0.3/install-sh -d $dir; \
  if test -r $lang.gmo; then \
    /usr/bin/install -c -m 644 $lang.gmo $dir/slick-greeter.mo; \
    echo "installing $lang.gmo as $dir/slick-greeter.mo"; \
  else \
    /usr/bin/install -c -m 644 ./$lang.gmo $dir/slick-greeter.mo; \
    echo "installing ./$lang.gmo as" \
	 "$dir/slick-greeter.mo"; \
  fi; \
  if test -r $lang.gmo.m; then \
    /usr/bin/install -c -m 644 $lang.gmo.m $dir/slick-greeter.mo.m; \
    echo "installing $lang.gmo.m as $dir/slick-greeter.mo.m"; \
  else \
    if test -r ./$lang.gmo.m ; then \
      /usr/bin/install -c -m 644 ./$lang.gmo.m \
	$dir/slick-greeter.mo.m; \
      echo "installing ./$lang.gmo.m as" \
	   "$dir/slick-greeter.mo.m"; \
    else \
      true; \
    fi; \
  fi; \
done
