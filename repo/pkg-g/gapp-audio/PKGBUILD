# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-audio'
pkgdesc='Goylin: Audio Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.5
pkgrel=4
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'audacity'
	'audacity-plugins'
	'ardour'
	'mixxx'
	'lmms'
	'bespokesynth'
	'carla'
	# 'catia-git' - Broken on Wayland? Carla can do the Job just fine.
	## Behringer
	x32edit
	xairedit
	#
	'lmms-orgmaker-samples'
	'leet-plugins'
	'harvid'
	'xjadeo'
	'ffmpeg'
	'lib32-gcc-libs'
	'lib32-glibc'
	'xdg-desktop-portal-impl'
	'lv2-host'
	'vst-host'
	'python-requests'
	'python-tornado'
	'cardinal'
	'cardinal-clap'
	'cardinal-data'
	'cardinal-lv2'
	'cardinal-vst'
	'cardinal-vst3'
	#
	'alsa-plugins'
	'alsa-firmware'
	'sof-firmware'
)

package() {
	install -vDm 644 -t ${pkgdir}/etc/skel skel.tar
	tar vxf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm -v ${pkgdir}/etc/skel/skel.tar
}