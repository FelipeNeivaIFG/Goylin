#!/bin/bash

_lockGFiles() {
	chattr +i /etc/lightdm/lightdm.conf
	chattr +i /etc/lightdm/slick-greeter.conf
	chattr +i /etc/pam.d/lightdm
}

_unlockGFiles() {
	chattr -i /etc/lightdm/lightdm.conf
	chattr -i /etc/lightdm/slick-greeter.conf
	chattr -i /etc/pam.d/lightdm
}


post_install() {
	systemctl enable lightdm
	_lockGFiles
}

pre_upgrade() {
	_unlockGFiles
}

post_upgrade() {
	_lockGFiles
}