pkgname='g-printer'
pkgdesc='Goylin: Printer'
url='https://github.com/FelipeNeivaIFG/Goylin'
group='goylin'

pkgver=24.5
pkgrel=2
arch=('x86_64')

source=('printers.conf')

md5sums=('SKIP')

depends=(
	'cups'
	'cups-browsed'
	'ipp-usb'
	'sane'
	'sane-airscan'
	'cups-pdf'
	'cups-filters'
	'ghostscript'
	'gsfonts'
	'print-manager'
	'hplip'
	'rpcbind'
	'system-config-printer'
)

install='pkg.install'

package() {
	install -vDm 640 -g cups -t ${pkgdir}/etc/cups/ printers.conf
}