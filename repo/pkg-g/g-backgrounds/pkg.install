#!/bin/bash

_unpackTar() {
	tar xf /usr/share/goylin/goylin.tar --overwrite --directory=/usr/share/goylin
	rm /usr/share/goylin/goylin.tar
	chmod -R a+r /usr/share/goylin/backgrounds/
}

pre_upgrade() {
	[ -d /usr/share/goylin/backgrounds ] && rm /usr/share/goylin/backgrounds/*
}

post_install() {
	_unpackTar
}

post_upgrade() {
	_unpackTar
}