# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='g-i3'
pkgdesc='Goylin: i3'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.5
pkgrel=2
arch=('x86_64')

source=(
	'skel.tar'
	'gi3Theme'
)

noextract=('skel.tar')

md5sums=('SKIP' 'SKIP')

depends=(
	'i3-wm'
	'i3status'
	'dmenu'
	'kitty'
	'imagemagick'
	'python-pygments'
	'rofi'
	'maim'
	'picom'
	'xorg-xprop'
	'xorg-xwininfo'
	'xwallpaper'
	'python-pywal'
	'xorg-xrandr'
	'arandr'
	'pavucontrol'
	'volumeicon'
	'ranger'
)

install='pkg.install'

package() {
	install -vDm 755 -t ${pkgdir}/usr/bin/ gi3Theme

	install -vDm 644 -t ${pkgdir}/etc/skel skel.tar
	tar vxf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm -v ${pkgdir}/etc/skel/skel.tar
}