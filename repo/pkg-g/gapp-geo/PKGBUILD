# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-geo'
pkgdesc='Goylin: Geotecnologia Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.2
pkgrel=3
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'google-earth-pro' 'qgis' 'marble' 'gapp-geo-sisvar'
	# EXTRAS
	'fcgi' 'gpsbabel' 'marble-maps' 'python-yaml'
	'python-jinja' 'python-gdal' 'python-psycopg2' 'python-pygments'
	'python-owslib' 'python-lxml'
)

package() {
	install -Dm 644 -t ${pkgdir}/etc/skel skel.tar
	tar xf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm ${pkgdir}/etc/skel/skel.tar
}