# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='g-desktop'
pkgdesc='Goylin: Desktop'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.2
pkgrel=1
arch=('x86_64')

source=(
	'skel.tar' 'user-dirs.defaults' 'goylin.tar' 'gWelcome'
	'lightdm.conf' 'slick-greeter.conf' 'lightdm' 'gLogoutScript'
	'xprofile' '00-keyboard.conf' 'sleep.conf' 'state'
)

md5sums=(
	'SKIP' 'SKIP' 'SKIP' 'SKIP'
	'SKIP' 'SKIP' 'SKIP' 'SKIP'
	'SKIP' 'SKIP' 'SKIP' 'SKIP'
)

install='pkg.install'

noextract=('goylin.tar' 'skel.tar')

depends=(
	'xdg-user-dirs' 'pam' 'xdg-desktop-portal' 'kitty'
	# GREETER
	'lightdm' 'gc-greeter' 'numlockx'
	# WAYLAND
	'wayland' 'lib32-wayland' 'xorg-xwayland'
	# AUDIO
	'pipewire' 'lib32-pipewire' 'pipewire-jack' 'lib32-pipewire-jack'
	'wireplumber' 'pipewire-audio' 'pipewire-alsa' 'pipewire-zeroconf'
	'pipewire-pulse'
	# TABLET
	'opentabletdriver'
	# 'huiontablet'
)

package() {
	install -Dm 644 -t ${pkgdir}/etc/ xprofile

	install -Dm 644 -t ${pkgdir}/etc/lightdm/ lightdm.conf
	install -Dm 644 -t ${pkgdir}/etc/lightdm/ slick-greeter.conf
	install -Dm 644 -t ${pkgdir}/var/lib/lightdm/.cache/slick-greeter state
	chmod 1770 ${pkgdir}/var/lib/lightdm/
	
	install -Dm 644 -t ${pkgdir}/etc/pam.d/ lightdm

	install -Dm 644 -t ${pkgdir}/etc/xdg/ user-dirs.defaults

	install -Dm 644 -t ${pkgdir}/etc/systemd/ sleep.conf

	install -Dm 644 -t ${pkgdir}/etc/X11/xorg.conf.d/ 00-keyboard.conf

	install -Dm 755 -t ${pkgdir}/usr/bin/ gLogoutScript

	install -Dm 755 -t ${pkgdir}/usr/bin/ gWelcome

	install -Dm 644 -t ${pkgdir}/etc/skel skel.tar
	tar xf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm ${pkgdir}/etc/skel/skel.tar

	install -Dm 644 -t ${pkgdir}/usr/share/goylin/ goylin.tar
	tar xf ${pkgdir}/usr/share/goylin/goylin.tar --overwrite --directory=${pkgdir}/usr/share/goylin/
	rm ${pkgdir}/usr/share/goylin/goylin.tar
}