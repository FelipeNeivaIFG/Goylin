# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-cad'
pkgdesc='Goylin: CAD Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=26.0
pkgrel=0
arch=('x86_64')

source=(
	'autocadWeb.desktop'
	'sketchupWeb.desktop'
	'autocadWeb.png'
	'sketchupWeb.png'
)

md5sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

depends=(
	'librecad'	# A 2D CAD drawing tool based on the community edition of QCad
	'qcad'	# A 2D CAD package based upon Qt
	# DEPS #
	'chromium'	# For AutocadWeb & SketchupWeb
)

package() {
	install -Dm 644 -t ${pkgdir}/usr/share/applications autocadWeb.desktop
	install -Dm 644 -t ${pkgdir}/usr/share/applications sketchupWeb.desktop
	install -Dm 644 -t ${pkgdir}/usr/share/icons autocadWeb.png
	install -Dm 644 -t ${pkgdir}/usr/share/icons sketchupWeb.png
}