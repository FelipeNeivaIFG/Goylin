# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='g-plasma'
pkgdesc='Goylin: Plasma'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.3
pkgrel=1
arch=('x86_64')

source=('kdeglobals' 'skel.tar' 'goylin.desktop.tar' 'goylindark.desktop.tar')

noextract=('skel.tar' 'goylin.desktop.tar' 'goylindark.desktop.tar')

md5sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

install='pkg.install'

depends=(
	'plasma-desktop' 'bluedevil' 'kscreen' 'plasma-nm'
	'plasma-pa' 'kde-gtk-config' 'kgamma' 'kscreen'
	'plasma-browser-integration' 'powerdevil' 'kinfocenter'
	'xdg-desktop-portal-kde' 'spectacle' 'konsole'
	'print-manager' 'system-config-printer' 'python-pysmbc' 'polkit-kde-agent'
	'plasma5support' 'plasma-integration' 'kwin' 'maliit-keyboard'
	'libplasma' 'libksysguard' 'libkscreen' 'layer-shell-qt'
	'kwayland-integration' 'kwayland' 'kdeplasma-addons' 'qt6-webengine'
	'kdeclarative' 'kde-cli-tools' 'dolphin' 'ffmpegthumbs'
	'kdegraphics-thumbnailers' 'purpose' 'dolphin-plugins' 'startup-notification'
	'plasma-disks' 'plasma-systemmonitor' 'drkonqi' 'breeze'
	'breeze5' 'breeze-gtk' 'kio' 'kio-extras'
	'audiocd-kio' 'kio-admin' 'kio-fuse' 'kio-gdrive'
	'kio-zeroconf' 'kio5' 'kio5-extras'
	'kimageformats' 'karchive' 'qt5-imageformats' 'kimageformats5'
	'icoutils' 'qt6-imageformats'

	#DEV
	# 'plasma-sdk'
)

package() {
	install -Dm 644 -t ${pkgdir}/etc/xdg/ kdeglobals

	install -Dm 644 -t ${pkgdir}/etc/skel skel.tar
	tar  xf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm ${pkgdir}/etc/skel/skel.tar

	install -Dm 644 -t ${pkgdir}/usr/share/plasma/look-and-feel/goylin.desktop/ goylin.desktop.tar
	tar xf ${pkgdir}/usr/share/plasma/look-and-feel/goylin.desktop/goylin.desktop.tar --overwrite --directory=${pkgdir}/usr/share/plasma/look-and-feel/goylin.desktop/
	rm ${pkgdir}/usr/share/plasma/look-and-feel/goylin.desktop/goylin.desktop.tar

	install -Dm 644 -t ${pkgdir}/usr/share/plasma/look-and-feel/goylindark.desktop/ goylindark.desktop.tar
	tar xf ${pkgdir}/usr/share/plasma/look-and-feel/goylindark.desktop/goylindark.desktop.tar --overwrite --directory=${pkgdir}/usr/share/plasma/look-and-feel/goylindark.desktop/
	rm ${pkgdir}/usr/share/plasma/look-and-feel/goylindark.desktop/goylindark.desktop.tar
}