# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='g-ad'
pkgdesc='Goylin: AD'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.3
pkgrel=1
arch=('x86_64')

source=(
	'gLoginAD' 'krb5.conf' 'nsswitch.conf' 'pam_winbind.conf'
	'smb.conf' 'su' 'system-auth' 'sshd_config'
	'90-mount.rules'
)

md5sums=(
	'SKIP' 'SKIP' 'SKIP' 'SKIP'
	'SKIP' 'SKIP' 'SKIP' 'SKIP'
	'SKIP'
)

install='pkg.install'

depends=(
	'samba'
	'smbclient'
	'bind'
	'python-dnspython'
	'bind'
	'krb5'
	'pam-krb5'
	'polkit'
	'avahi'
	'pam'
	
)

package() {
	install -Dm 644 -t ${pkgdir}/etc/ krb5.conf
	install -Dm 644 -t ${pkgdir}/etc/ nsswitch.conf

	install -Dm 644 -t ${pkgdir}/etc/samba/ smb.conf

	install -Dm 644 -t ${pkgdir}/etc/sshd/ sshd_config

	install -Dm 644 -t ${pkgdir}/etc/security/ pam_winbind.conf

	install -Dm 750 -t ${pkgdir}/usr/bin/ gLoginAD

	install -Dm 644 -t ${pkgdir}/etc/pam.d/ system-auth
	install -Dm 644 -t ${pkgdir}/etc/pam.d/ su

	install -Dm 644 -t ${pkgdir}/etc/polkit-1/rules.d/ 90-mount.rules
	chmod 750 ${pkgdir}/etc/polkit-1/rules.d/
}