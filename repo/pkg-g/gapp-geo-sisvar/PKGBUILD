# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-geo-sisvar'
pkgdesc='Goylin: Geotecnologia App Sisvar'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.3
pkgrel=1
arch=('x86_64')

source=('sisvar.tar' 'sisvar.desktop' 'sisvaricon.png')

noextract=('sisvar.tar')

md5sums=('SKIP' 'SKIP' 'SKIP')

depends=('wine' 'wine-mono')

package() {
	install -Dm 644 -t ${pkgdir}/etc/skel/.sisvar sisvar.tar
	tar xf ${pkgdir}/etc/skel/.sisvar/sisvar.tar --overwrite --directory=${pkgdir}/etc/skel/.sisvar
	rm ${pkgdir}/etc/skel/.sisvar/sisvar.tar

	install -Dm 644 -t ${pkgdir}/usr/share/applications sisvar.desktop
	install -Dm 644 -t ${pkgdir}/usr/share/icons sisvaricon.png
}