pkgname='gapp-video'
pkgdesc='Goylin: Video Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.5
pkgrel=2
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'kdenlive'
	'handbrake'
	'obs-studio'
	'shotcut'
	'flowblade'
	'dcpomatic'
	#
	'bigsh0t'
	'dvgrab'
	'ffmpeg'
	'kimageformats'
	'mediainfo'
	'opencv'
	'opentimelineio'
	'python-openai-whisper'
	'python-srt_equalizer'
	'python-vosk'
	'qt6-imageformats'
	'swh-plugins'
	'python-pip'
	'gst-plugins-good'
	'gst-libav'
	'libfdk-aac'
	'luajit'
	'python'
	'sndio'
	'droidcam-obs-plugin'
)

package() {
	install -vDm 644 -t ${pkgdir}/etc/skel skel.tar
	tar vxf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm -v ${pkgdir}/etc/skel/skel.tar
}