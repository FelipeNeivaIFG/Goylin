# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='gapp-base'
pkgdesc='Goylin: Base Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.2
pkgrel=1
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'evince' 'onlyoffice-bin' 'brave-bin' 'vlc'
	'shotwell' 'firefox' 'libreoffice-fresh' 'kate'
	'python-spotdl' 'yt-dlp' 'elisa' 'font-manager'
	
	# EXTRAS
	'aalib' 'lib32-flac' 'libcaca' 'libdvdcss'
	'libdvdnav' 'libdvdread' 'libkate' 'lib32-libogg'
	'lib32-libpng' 'lib32-libpulse' 'libshout' 'protobuf'
	'sdl12-compat' 'sdl_image' 'twolame'
)

package() {
	install -Dm 644 -t ${pkgdir}/etc/skel skel.tar
	tar xf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm ${pkgdir}/etc/skel/skel.tar
}