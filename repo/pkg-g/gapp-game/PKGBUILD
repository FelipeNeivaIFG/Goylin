package() {
	install -Dm 755 -t ${pkgdir}/usr/share/applications tlauncher.desktop
	install -Dm 644 -t ${pkgdir}/opt/tlauncher tlauncher.tar
	tar xf ${pkgdir}/opt/tlauncher/tlauncher.tar --overwrite --directory=${pkgdir}/opt/tlauncher/
	chmod 755 ${pkgdir}/opt/tlauncher/TLauncher.jar
	rm ${pkgdir}/opt/tlauncher/tlauncher.tar
}