pkgname='gapp-game'
pkgdesc='Goylin: Games'
url='https://github.com/FelipeNeivaIFG/Goylin'
group='goylin'

pkgver=24.5
pkgrel=2
arch=('x86_64')

source=('tlauncher.tar' 'tlauncher.desktop')

noextract=('tlauncher.tar')

md5sums=('SKIP' 'SKIP')

depends=(
	# 'itch-bin' # <- This will make a mess for sure... ^_^
	# 'steam' # <- This will make a mess for sure... ^_^
	'0ad'
	'mari0'
	'kpat'
	'ksquares'
	'knights'
	'gnome-mines'
	'gnome-mahjongg'
	'gnome-klotski'
	'gnome-sudoku'
	'minecraft-launcher'
	'ddnet'
	'ltris'
	'lix'
	'maniadrive'
	#
	'jdk-openjdk'
	'discord-game-sdk'
	'dosbox'
	'fluidsynth'
	'gamemode'
	'lib32-gamemode'
	'lib32-vkd3d'
	'lib32-vulkan-icd-loader'
	'vkd3d'
	'vulkan-icd-loader'
	'vulkan-tools'
	'xorg-xgamma'
)

package() {
	install -vDm 755 -t ${pkgdir}/usr/share/applications tlauncher.desktop
	install -vDm 644 -t ${pkgdir}/opt/tlauncher tlauncher.tar
	tar vxf ${pkgdir}/opt/tlauncher/tlauncher.tar --overwrite --directory=${pkgdir}/opt/tlauncher/
	chmod -v 755 ${pkgdir}/opt/tlauncher/TLauncher.jar
	rm -v ${pkgdir}/opt/tlauncher/tlauncher.tar
}