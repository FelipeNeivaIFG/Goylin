pkgname='gapp-image'
pkgdesc='Goylin: Image Apps'
url='https://github.com/FelipeNeivaIFG/Goylin'
group=('goylin')

pkgver=24.5
pkgrel=1
arch=('x86_64')

source=('skel.tar')

noextract=('skel.tar')

md5sums=('SKIP')

depends=(
	'gimp'
	'inkscape'
	'krita'
	'darktable'
	'rawtherapee'
	'pixelorama-bin'
	#
	'krita-plugin-gmic'
	'libmypaint'
	'mypaint-brushes'
	'potrace'
	'fig2dev'
	'gnuplot'
	'gimp-plugin-gmic'
	'optipng'
	'ghostscript'
	'gutenprint'
	'gvfs'
	'fig2dev'
	'pstoedit'
	'texlive-pstricks'
	'kimageformats5'
	'kseexpr'
	'libheif'
	'libjxl'
	'poppler-qt5'
	'python-pyqt5'
	'dcraw'
	'perl-image-exiftool'
	'imagemagick'
)

package() {
	install -vDm 644 -t ${pkgdir}/etc/skel skel.tar
	tar vxf ${pkgdir}/etc/skel/skel.tar --overwrite --directory=${pkgdir}/etc/skel/
	rm -v ${pkgdir}/etc/skel/skel.tar
}