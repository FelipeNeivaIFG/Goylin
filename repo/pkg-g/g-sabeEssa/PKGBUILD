# Maintainer: Felipe Neiva <felipe.neiva@ifg.edu.br>
pkgname='g-sabeEssa'
pkgdesc='Goylin: Sabe Essa?: Aplicativo de curiosidades'
url='https://github.com/FelipeNeivaIFG/Goylin'
group='goylin'

pkgver=26.0
pkgrel=1
arch=('x86_64')

source=('sabeEssa.x86_64' 'sabeEssa.desktop' 'sabeEssa.png')

md5sums=('SKIP' 'SKIP' 'SKIP')

package() {
	install -Dm 755 -t ${pkgdir}/usr/share/applications/ sabeEssa.desktop
	install -Dm 755 -t ${pkgdir}/etc/skel/.config/autostart/ sabeEssa.desktop
	install -Dm 755 -t ${pkgdir}/opt/sabeEssa/ sabeEssa.x86_64
	install -Dm 644 -t ${pkgdir}/opt/sabeEssa/ sabeEssa.png
}